# ── Optional: external backend override ──────────────────────────────
# If set, form submissions are forwarded to this server's
# /api/contact and /api/event-register endpoints instead of using
# the built-in email + local-file handler below. Leave blank to use
# the built-in handler.
FASTIFY_API_URL=

# ── Built-in email notifications (used when FASTIFY_API_URL is blank) ─
# Works with Gmail (use an App Password, not your normal password),
# Outlook/Office365, or any SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="New Delhi Dialogues <no-reply@newdelhidialogues.org>"

# Where each form's notification email gets sent
CONTACT_RECIPIENT_EMAIL=
EVENT_REGISTER_RECIPIENT_EMAIL=
